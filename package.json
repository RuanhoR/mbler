{
  "name": "mbler",
  "version": "0.1.8-beta",
  "description": "一个针对Minecraft JavaScript API 的CLI工具，让你的附加包版本管理更简单",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RuanhoR/mbler.git"
  },
  "keywords": [
    "Minecraft",
    "build",
    "cli"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "license": "MIT",
  "type": "commonjs",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "types": "./dist/types/index.d.ts",
  "scripts": {
    "cli": "node bin/mbler.js",
    "build": "rollup -c",
    "test": "pnpm build && cd __test__ && pnpm test"
  },
  "dependencies": {
    "@rollup/plugin-terser": "0.4.4",
    "@mbler/mcx-core": "0.0.3-alpha.r202406291200",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "adm-zip": "0.5.16",
    "chokidar": "4.0.3",
    "dayjs": "1.11.18",
    "npm-registry-fetch": "19.1.1",
    "rollup": "4.59.0",
    "terser": "5.44.0",
    "typescript": "5.9.3"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "bin": {
    "mbler": "bin/mbler.js"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.0",
    "@types/adm-zip": "0.5.7",
    "@types/babel__generator": "7.27.0",
    "@types/babel__traverse": "7.28.0",
    "@types/node": "25.0.9",
    "@types/npm-registry-fetch": "8.0.9",
    "globals": "17.0.0",
    "tslib": "^2.8.1"
  }
}
