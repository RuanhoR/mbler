{
  "name": "mbler",
  "version": "0.2.3-alpha.r2",
  "description": "mcx DSL cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RuanhoR/mbler.git"
  },
  "keywords": [
    "Minecraft",
    "build",
    "cli"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "license": "MIT",
  "type": "commonjs",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.mjs",
      "require": "./dist/index.js"
    },
    "./build": {
      "types": "./dist/build.d.ts",
      "import": "./dist/build.esm.mjs",
      "require": "./dist/build.js"
    }
  },
  "types": "./dist/types/index.d.ts",
  "scripts": {
    "cli": "node bin/mbler.js",
    "build": "rollup -c",
    "test": "pnpm build && cd __test__ && pnpm test"
  },
  "dependencies": {
    "@mbler/mcx": "0.0.3-alpha.r1",
    "@mbler/mcx-core": "0.0.6-alpha.r20260416.2",
    "@mbler/mcx-server": "link:../mcx-language-server/packages/server",
    "@mbler/mcx-types": "0.0.3-rc.5",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "0.4.4",
    "@rollup/plugin-typescript": "12.3.0",
    "@volar/language-core": "^2.4.28",
    "@volar/typescript": "^2.4.28",
    "adm-zip": "0.5.16",
    "chalk": "^5.6.2",
    "chokidar": "4.0.3",
    "dayjs": "1.11.18",
    "npm-registry-fetch": "19.1.1",
    "rollup": "4.59.0",
    "terser": "5.44.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vscode-uri": "^3.1.0"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "bin": {
    "mbler": "bin/mbler.js",
    "mcx-tsc": "bin/mcx-tsc.js"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.0",
    "@types/adm-zip": "0.5.7",
    "@types/babel__generator": "7.27.0",
    "@types/babel__traverse": "7.28.0",
    "@types/node": "25.0.9",
    "@types/npm-registry-fetch": "8.0.9",
    "globals": "17.0.0",
    "rollup-plugin-dts": "6.3.0"
  }
}
